{
  "manifest_version": 3,
  "name": "Time Stone — Portfolio Sentinel",
  "version": "1.0.0",
  "description": "A mystical sentinel that watches the threads of time and alerts you when the portfolio is updated.",
  "permissions": ["storage", "notifications", "alarms"],
  "host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Time Stone",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
